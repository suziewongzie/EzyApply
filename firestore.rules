rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Global safety net - default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // 2. Transitive helper primitives
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    // 3. Validation Blueprint
    function isValidOnboardingDraft(data) {
      return data.keys().hasAll(['profile', 'currentIndex', 'updatedAt', 'userId'])
        && data.keys().size() == 4
        && data.profile is map
        && data.currentIndex is int
        && data.updatedAt is string
        && data.userId is string
        && data.userId == request.auth.uid;
    }

    // 4. Secure Match for Onboarding Drafts
    match /onboarding_drafts/{userId} {
      allow get: if isOwner(userId) && isValidId(userId);
      allow create: if isOwner(userId) && isValidId(userId) && isValidOnboardingDraft(incoming());
      allow update: if isOwner(userId) && isValidId(userId) && isValidOnboardingDraft(incoming())
        && incoming().userId == resource.data.userId;
      allow delete: if isOwner(userId) && isValidId(userId);
    }

    // 5. Secure Match for Applications (Applicant access & Admin querying)
    match /applications/{userId} {
      allow get: if (isOwner(userId) || userId == 'settings_general') && isValidId(userId);
      allow list: if isSignedIn();
      allow create, update: if isSignedIn() && isValidId(userId);
      allow delete: if isSignedIn() && isValidId(userId);
    }
  }
}
